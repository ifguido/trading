# Binance API
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Database (PostgreSQL or SQLite)
DATABASE_URL=sqlite+aiosqlite:///data/cryptotrader.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cryptotrader

# Web UI login credentials
# Generate password hash: python -c "import hashlib; print(hashlib.sha256(b'YOUR_PASSWORD').hexdigest())"
WEB_USERNAME=admin
WEB_PASSWORD_HASH=

# Auto-start bot on server startup (true/false)
AUTO_START=false

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
